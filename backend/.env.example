# Get a free API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Postgres connection string (must have pgvector extension)
# Local:    postgresql://youruser@localhost:5432/ragchatbot
# Supabase: postgresql://postgres.[ref]:[password]@aws-1-....pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://youruser@localhost:5432/ragchatbot

# Server config
PORT=8000

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=dev-secret-key-change-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Gemini (used for embeddings only)
GEMINI_EMBED_MODEL=gemini-embedding-001

# ZilRouter AI (used for answer generation)
ZILROUTER_URL=https://zilrouter.ngrok.app
ZILROUTER_API_KEY=your_zilrouter_api_key_here
